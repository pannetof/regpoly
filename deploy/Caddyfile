# Caddy v2 config for regpoly_monorepo (dockerize-plan Phase 4 / 5).
#
# All values come from compose env: DOMAIN, LE_EMAIL,
# BASIC_AUTH_USER, BASIC_AUTH_HASH (set in deploy/.env).
#
# DNS setup (Phase 5): the domain must be on Cloudflare in DNS-only
# mode (gray cloud) so Caddy's HTTP-01 ACME challenge reaches the
# origin on port 80. Proxied mode (orange cloud) would force a switch
# to DNS-01 + the caddy-dns/cloudflare plugin (custom xcaddy build).
{
    email {$LE_EMAIL}

    # Uncomment for first-deploy iteration: use Let's Encrypt staging
    # to avoid burning the prod rate limit while debugging DNS / TLS.
    # acme_ca https://acme-staging-v02.api.letsencrypt.org/directory
}

{$DOMAIN} {
    encode gzip

    # Healthcheck: exact-path-only exemption from basic auth, so
    # UptimeRobot (Phase 7) doesn't need to share credentials with a
    # third-party service. Includes the trailing-slash variant to
    # defend against the "/healthz" vs "/healthz/" matcher subtlety.
    @public {
        path /healthz /healthz/
    }
    handle @public {
        reverse_proxy web:8000
    }

    handle {
        basicauth {
            {$BASIC_AUTH_USER} {$BASIC_AUTH_HASH}
        }
        reverse_proxy web:8000 {
            # Required for the SSE progress streams. Without
            # `flush_interval -1`, Caddy buffers the response body and
            # the EventSource sees no events until the connection
            # closes. Caddy v2.5+ also auto-skips gzip for
            # text/event-stream, which the SSE handler sets explicitly.
            flush_interval -1
        }
    }
}
