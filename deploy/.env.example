# Copy to deploy/.env and edit DB_PASSWORD. After writing,
# `chmod 600 deploy/.env` — `docker compose config` will otherwise
# print this file's contents (including the password) to anyone with
# shell access.

# ─── Required ────────────────────────────────────────────────────────
# Database password. Used by the `db` container as POSTGRES_PASSWORD
# AND by web + worker in their REGPOLY_DB_URL. Pick a strong value;
# rotate by editing this file, then `docker compose up -d` (PG accepts
# the changed env; the existing role in PG still has the old password
# until you `ALTER USER`).
DB_PASSWORD=replace-me

# ─── Optional ────────────────────────────────────────────────────────
# Bind address of the web service on the host.
#   127.0.0.1 (default): host-local only. Reach via http://localhost:8000
#     from the host itself, or via `ssh -L 8000:127.0.0.1:8000 user@host`
#     from your workstation.
#   0.0.0.0: bind on every host interface. Use this when something
#     else fronts the stack (cloudflared on a different machine,
#     Tailscale on this host, a LAN reverse proxy, etc.). The stack
#     itself adds no TLS or auth — the front layer must.
# WEB_BIND_ADDR=127.0.0.1

# Image tag. Default `latest` follows the rolling published tag. Pin
# to a specific `sha-<short>` to roll back to a known commit.
# REGPOLY_TAG=latest

# Postgres image tag. Override only when validated.
# POSTGRES_TAG=16.6-alpine
