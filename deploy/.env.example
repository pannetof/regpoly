# Copy to deploy/.env (gitignored) and fill in real values.
# All variables are required unless marked optional.

# ─── Domain + TLS ────────────────────────────────────────────────────
# Public hostname; matches the Cloudflare A record (DNS-only mode).
DOMAIN=regpoly.frpanneton.ca

# Email used for Let's Encrypt account registration. Caddy sends
# cert-expiry warnings here (renewal is automatic; this is fallback).
# Not surfaced publicly.
LE_EMAIL=frpanneton@gmail.com

# ─── HTTP basic auth (the only authentication on the app) ────────────
# Username — anything; included in browser prompt.
BASIC_AUTH_USER=regpoly

# bcrypt hash of the chosen password. Generate with:
#   docker run --rm caddy:2-alpine caddy hash-password
# Use a strong password (≥20 random chars); the brute-force defense
# is the password's entropy, not rate limiting.
BASIC_AUTH_HASH=$2a$14$REPLACEME...

# ─── Database password ───────────────────────────────────────────────
# Used by both the `db` container (POSTGRES_PASSWORD) and by the web /
# worker / init containers in their REGPOLY_DB_URL. Rotate by editing
# this file and `docker compose up -d` (PG accepts the changed env;
# existing DB is unaffected — the user inside Postgres still has the
# old password until you ALTER USER).
DB_PASSWORD=REPLACEME

# ─── Image tag ───────────────────────────────────────────────────────
# Which GHCR image to run. Tag-driven Pattern B release:
#  - `latest` moves only on `vX.Y.Z` git tag pushes
#  - `sha-<short>` is immutable per master commit
# To roll back: set this to a previous sha-<short> and run deploy.sh.
REGPOLY_TAG=latest

# ─── Optional: pinned upstream image versions ────────────────────────
# Default in compose.yml: postgres 16.6-alpine, caddy 2.8-alpine.
# Override here only when validated against the current code.
# POSTGRES_TAG=16.6-alpine
# CADDY_TAG=2.8-alpine

# Public GHCR image — no GHCR_TOKEN needed because the package is
# public (after the one-time visibility toggle on first push; see
# deploy/README.md). If you ever make the package private, add:
# GHCR_TOKEN=ghp_...

# No backup-related env vars. Backups are NAS-side (the NAS pulls
# pg_dump output over SSH; see deploy/README.md).
